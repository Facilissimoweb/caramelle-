# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE ANALYTICS 4
# GA_API_SECRET: The API Secret created in GA4 for Measurement Protocol
GA_API_SECRET="UX9LHQZDSjyMmva3Sc42MA"
# VITE_GA_MEASUREMENT_ID: The public Measurement ID (starts with G-) for client-side tracking
VITE_GA_MEASUREMENT_ID="G-WXMTZF53RL"
# GA_MEASUREMENT_ID: The Measurement ID (starts with G-) for server-side tracking
GA_MEASUREMENT_ID="G-WXMTZF53RL"

# META PIXEL
# VITE_META_PIXEL_ID: The public Meta Pixel ID for tracking
VITE_META_PIXEL_ID="109823485761234"

# GROQ API KEY: Required for Groq AI chat routing if prioritized
GROQ_API_KEY="MY_GROQ_API_KEY"

# SMTP Mail Configuration
# These are required to send real emails from the contact form to facilissimoweb.mc@gmail.com
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-email@gmail.com"
SMTP_PASS="your-smtp-password-or-app-password"


